# Optional data files not built by default
data/optional/*.json

# Large enrichment files — built on demand
data/enrichment/sentence-difficulty.json
data/enrichment/frequency-tatoeba.json
data/enrichment/frequency-jesc.json

# Full word list (216k entries, ~150 MB) — built on demand, committed as release artifact
data/core/words-full.json

# KFTT sentence corpus (~220 MB) — built on demand, committed as release artifact
data/corpus/sentences-kftt.json

# Full Tatoeba corpus (~80 MB) — built on demand, committed as release artifact
data/corpus/sentences-tatoeba-full.json

# JESC subtitle corpus (~large) — built on demand, committed as release artifact
data/corpus/sentences-jesc.json

# WikiMatrix parallel corpus (~large) — built on demand, committed as release artifact
data/corpus/sentences-wikimatrix.json

# WordNet synonym data (~large) — built on demand
data/cross-refs/wordnet-synonyms.json

# Full-JMdict cross-references (built alongside words-full.json)
data/cross-refs/kanji-to-words-full.json
data/cross-refs/word-to-kanji-full.json
data/cross-refs/reading-to-words-full.json

# Phase 4 data outputs (large, built on demand)
data/phase4/

# Export outputs (Yomitan ZIP, Parquet, etc.)
dist/

# Scratch space for experiments — never committed
scratch/*
!scratch/.gitkeep

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS
.directory

# Environment files
.env
.env.local
.envrc

# Temporary
*.tmp
*.log
*.bak
