# Optional data files not built by default
data/optional/*.json

# Full word list (216k entries, ~150 MB) — built on demand, committed as release artifact
data/core/words-full.json

# KFTT sentence corpus (~220 MB) — built on demand, committed as release artifact
data/corpus/sentences-kftt.json

# Full-JMdict cross-references (built alongside words-full.json)
data/cross-refs/kanji-to-words-full.json
data/cross-refs/word-to-kanji-full.json
data/cross-refs/reading-to-words-full.json

# Export outputs (Yomitan ZIP, Parquet, etc.)
dist/

# Scratch space for experiments — never committed
scratch/*
!scratch/.gitkeep

