{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jkindrix/japanese-language-data/schemas/stroke-order.schema.json",
  "title": "Stroke order index",
  "description": "Index file mapping each kanji character to its stroke-order SVG filename (from KanjiVG) and total stroke count. The actual SVG files live in data/enrichment/stroke-order/ and are not validated by this schema.",
  "schemaVersion": "0.0.0",
  "type": "object",
  "required": ["metadata", "characters"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "characters": {
      "type": "object",
      "description": "Object keyed by kanji character.",
      "additionalProperties": {
        "$ref": "#/$defs/strokeOrderEntry"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["source", "license", "generated", "count", "field_notes"],
      "properties": {
        "source": {"type": "string"},
        "source_url": {"type": "string", "format": "uri"},
        "license": {"type": "string"},
        "source_version": {"type": "string"},
        "generated": {"type": "string", "format": "date"},
        "count": {"type": "integer", "minimum": 0},
        "field_notes": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "attribution": {"type": "string"},
        "svg_directory": {
          "type": "string",
          "description": "Path relative to the dataset root where SVG files are stored."
        }
      }
    },
    "strokeOrderEntry": {
      "type": "object",
      "required": ["svg"],
      "properties": {
        "svg": {
          "type": ["string", "null"],
          "description": "SVG filename relative to the svg_directory, or null if no SVG exists for this character."
        },
        "stroke_count": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "unicode": {
          "type": "string",
          "description": "Unicode codepoint in hex."
        }
      }
    }
  }
}
