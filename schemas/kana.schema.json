{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jkindrix/japanese-language-data/schemas/kana.schema.json",
  "title": "Kana",
  "description": "Hand-curated dataset of hiragana, katakana, and kana variants (dakuten, handakuten, yōon). Each entry describes one kana character with its romanization, type classification, stroke count, and usage notes.",
  "schemaVersion": "0.8.0",
  "type": "object",
  "required": [
    "metadata",
    "kana"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/metadata",
      "description": "Build metadata: source provenance, license, generation date, counts, field documentation, and attribution."
    },
    "kana": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/kanaEntry"
      },
      "description": "Array of hiragana and katakana character entries."
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": [
        "source",
        "license",
        "generated",
        "count",
        "field_notes"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string"
        },
        "source_version": {
          "type": "string"
        },
        "generated": {
          "type": "string",
          "format": "date"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "field_notes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "authorship_caveat": {
          "type": "string",
          "description": "Caveat about the authorship and quality of hand-curated fields."
        }
      },
      "additionalProperties": false
    },
    "kanaEntry": {
      "type": "object",
      "required": [
        "character",
        "script",
        "romaji",
        "type"
      ],
      "properties": {
        "character": {
          "type": "string",
          "description": "The kana character itself.",
          "minLength": 1,
          "maxLength": 4
        },
        "script": {
          "type": "string",
          "enum": [
            "hiragana",
            "katakana"
          ],
          "description": "Which kana script this character belongs to."
        },
        "romaji": {
          "type": "string",
          "description": "Hepburn romanization."
        },
        "romaji_alt": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Alternative romanizations (Kunrei, Nihon-shiki, etc.)."
        },
        "type": {
          "type": "string",
          "enum": [
            "base",
            "dakuten",
            "handakuten",
            "yoon",
            "yoon_dakuten",
            "yoon_handakuten",
            "sokuon",
            "other"
          ],
          "description": "Classification of the kana: base form, voiced (dakuten), semi-voiced (handakuten), palatalized combination (yōon), etc."
        },
        "base": {
          "type": "string",
          "description": "For derived forms (dakuten/handakuten/yōon), the base kana this is derived from.",
          "minLength": 1
        },
        "stroke_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 10,
          "description": "Stroke count for base/dakuten/handakuten/sokuon forms. Null for yōon compounds, which are composed of two base kana and do not have a single canonical stroke count."
        },
        "unicode": {
          "type": "string",
          "description": "Unicode codepoint in hex (lowercase)."
        },
        "usage_notes": {
          "type": "string",
          "description": "Human-readable notes on when and how this kana is used."
        }
      },
      "additionalProperties": false
    }
  }
}
