{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jkindrix/japanese-language-data/schemas/furigana.schema.json",
  "title": "Furigana alignment",
  "description": "Maps individual kanji within compound words to their readings (ruby text). Each entry provides the segmented reading alignment for a (text, reading) pair from JmdictFurigana.",
  "schemaVersion": "0.9.0",
  "type": "object",
  "required": ["metadata", "entries"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/furiganaEntry"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["source", "license", "generated", "count", "field_notes"],
      "properties": {
        "source": { "type": "string" },
        "source_url": { "type": "string", "format": "uri" },
        "license": { "type": "string" },
        "generated": { "type": "string", "format": "date" },
        "count": { "type": "integer", "minimum": 0 },
        "attribution": { "type": "string" },
        "field_notes": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "furiganaEntry": {
      "type": "object",
      "required": ["text", "reading", "segments"],
      "properties": {
        "text": {
          "type": "string",
          "description": "Kanji writing of the word."
        },
        "reading": {
          "type": "string",
          "description": "Full kana reading."
        },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/segment"
          },
          "description": "Ordered reading segments mapping text chunks to their readings."
        }
      },
      "additionalProperties": false
    },
    "segment": {
      "type": "object",
      "required": ["ruby"],
      "properties": {
        "ruby": {
          "type": "string",
          "description": "Text segment (kanji or kana characters)."
        },
        "rt": {
          "type": "string",
          "description": "Furigana reading for kanji segments. Omitted for kana-only segments."
        }
      },
      "additionalProperties": false
    }
  }
}
