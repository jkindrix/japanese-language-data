{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jkindrix/japanese-language-data/schemas/expressions.schema.json",
  "title": "Expressions",
  "description": "Lexicalized grammar patterns extracted from JMdict entries that carry the 'exp' (expression) part-of-speech tag. These are fixed phrases, set expressions, idioms, and grammaticalized constructions that function as single lexical units. Unlike the curated grammar dataset in grammar.json (which provides compositional grammar patterns with formation rules), this file is a straightforward extraction of JMdict exp entries, retaining their full sense structure for convenience of use as a grammar/expression reference.",
  "schemaVersion": "0.8.0",
  "type": "object",
  "required": [
    "metadata",
    "expressions"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/metadata",
      "description": "Build metadata: source provenance, license, generation date, counts, field documentation, and attribution."
    },
    "expressions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/expressionEntry"
      },
      "description": "Array of lexicalized expression entries from JMdict."
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": [
        "source",
        "license",
        "generated",
        "count",
        "field_notes"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string"
        },
        "source_version": {
          "type": "string"
        },
        "generated": {
          "type": "string",
          "format": "date"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "field_notes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "attribution": {
          "type": "string"
        },
        "upstream_dict_date": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "expressionEntry": {
      "type": "object",
      "required": [
        "id",
        "text",
        "reading",
        "meanings"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "JMdict entry ID (same ID used in words.json)."
        },
        "text": {
          "type": "string",
          "description": "Primary kanji writing of the expression, or kana if kana-only."
        },
        "reading": {
          "type": "string",
          "description": "Primary kana reading."
        },
        "all_kanji_writings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "all_kana_readings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "meanings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "English glosses from JMdict senses tagged as 'exp'."
        },
        "common": {
          "type": "boolean"
        },
        "misc": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Additional misc tags from JMdict (e.g., politeness markers, archaic, slang, etc.)."
        },
        "jlpt_waller": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "N1",
            "N2",
            "N3",
            "N4",
            "N5",
            null
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
