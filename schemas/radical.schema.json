{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jkindrix/japanese-language-data/schemas/radical.schema.json",
  "title": "Radicals",
  "description": "Bidirectional radical data combining KRADFILE (kanji → component radicals) and RADKFILE (radical → kanji containing it), both from EDRDG via scriptin/jmdict-simplified.",
  "schemaVersion": "0.3.0",
  "type": "object",
  "required": ["metadata", "radicals", "kanji_to_radicals"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "radicals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/radicalEntry"
      }
    },
    "kanji_to_radicals": {
      "type": "object",
      "description": "Map of each kanji character to the list of radicals that compose it.",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"}
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["source", "license", "generated", "field_notes"],
      "properties": {
        "source": {"type": "string"},
        "source_url": {"type": "string", "format": "uri"},
        "license": {"type": "string"},
        "source_version": {"type": "string"},
        "generated": {"type": "string", "format": "date"},
        "field_notes": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "attribution": {"type": "string"}
      }
    },
    "radicalEntry": {
      "type": "object",
      "required": ["radical", "stroke_count", "kanji"],
      "properties": {
        "radical": {
          "type": "string",
          "description": "The radical character itself."
        },
        "stroke_count": {
          "type": "integer",
          "minimum": 1
        },
        "classical_number": {
          "type": ["integer", "null"],
          "description": "Classical (Kangxi) radical number, 1-214.",
          "minimum": 1,
          "maximum": 214
        },
        "meanings": {
          "type": "array",
          "items": {"type": "string"}
        },
        "kanji": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Kanji characters that contain this radical as a component."
        }
      }
    }
  }
}
